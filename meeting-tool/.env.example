# ── 미팅 회의록 도구 설정 ────────────────────────────────
# 이 파일을 복사해서 이름을 ".env" 로 바꾼 뒤, 아래 값을 채우세요.
# (따옴표 없이, = 뒤에 값만 붙여넣으면 됩니다)

# Claude 요약용 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Notion 통합 '미팅 비서'의 액세스 토큰 (https://www.notion.so/my-integrations)
NOTION_API_KEY=

# 회의록을 저장할 Notion 페이지 ID (페이지 URL 끝의 32자리)
NOTION_PARENT_PAGE_ID=

# (데이터베이스에 저장하려면 위 줄 대신 아래 두 줄을 사용)
# NOTION_DATABASE_ID=
# NOTION_TITLE_PROPERTY=이름
