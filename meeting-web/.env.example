# ── 회의록 웹앱 환경변수 (Vercel > Settings > Environment Variables 에 입력) ──

# 사이트 접속 비밀번호 (회사 사람들과 공유할 공용 비밀번호)
SITE_PASSWORD=change-this-password

# 세션 쿠키 서명용 비밀 키 (길고 랜덤하게)
# 예) openssl rand -base64 32
AUTH_SECRET=change-this-to-a-long-random-secret

# Claude 요약용 키 (https://console.anthropic.com) — 없으면 요약 없이 전문만 저장
ANTHROPIC_API_KEY=

# Notion 통합 토큰 (https://www.notion.so/my-integrations → 액세스 토큰)
NOTION_API_KEY=

# 회의록을 저장할 Notion 페이지 ID (페이지 URL 끝의 32자리)
NOTION_PARENT_PAGE_ID=

# (데이터베이스에 저장하려면 위 줄 대신 아래를 사용)
# NOTION_DATABASE_ID=
# NOTION_TITLE_PROPERTY=이름
