# 길드원에게 공유할 공용 접속 비밀번호
SITE_PASSWORD=change-this-password

# 세션 쿠키 서명용 비밀 키 (길고 랜덤한 문자열로 설정)
# 예) openssl rand -base64 32
AUTH_SECRET=change-this-to-a-long-random-secret

# (선택) 여러 명이 실시간 공유하려면 Vercel KV(Upstash Redis)를 연결하세요.
# Vercel에서 KV/Upstash를 프로젝트에 연결하면 아래 값이 자동 주입됩니다.
# 두 가지 명명 규칙 모두 지원합니다. (없으면 로컬 파일 .data/store.json 에 저장)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# 또는
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
